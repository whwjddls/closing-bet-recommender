# closing-bet-recommender 백엔드 환경변수 템플릿
# 사용법: 이 파일을 복사해 backend/.env 로 만들고 값 채우기 → uvicorn 기동 시 자동 주입(app.main 이 load_dotenv)
# .env 는 git 에 안 올라감(.gitignore).

# ── KRX (data.krx.co.kr) — pykrx 데이터(지수·수급·시장폭·섹터·오버나잇갭·백테스트) 조회용 계정 ──
# pykrx 1.2.8+ 는 KRX 로그인 필요. https://data.krx.co.kr 무료 회원가입 후 아이디/비번.
KRX_ID=
KRX_PW=

# ── KIS (한국투자증권) — 15:20 실시간 시세/거래대금 랭킹/지수. https://apiportal.koreainvestment.com ──
KIS_APP_KEY=
KIS_APP_SECRET=
# 실전(기본): https://openapi.koreainvestment.com:9443  /  모의투자: https://openapivts.koreainvestment.com:29443
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# 계좌번호 8자리-2자리(예: 12345678-01). KIS 개발자센터/앱에서 발급받은 계좌.
KIS_ACCOUNT=

# ── DART (전자공시) — 희석 공시 veto. 무료 발급: https://opendart.fss.or.kr ──
DART_API_KEY=

# ── (선택) 텔레그램 알림 — 15:20 런 결과를 폰으로 발송. 비우면 데스크톱 알림으로 폴백 ──
# 1) 텔레그램에서 @BotFather 에게 /newbot → 봇 이름 정하면 토큰을 준다.
# 2) 만든 봇과 대화창을 열고 아무 메시지나 한 번 보낸다(봇이 먼저 말 걸 수 없음).
# 3) https://api.telegram.org/bot<토큰>/getUpdates 를 브라우저로 열어 result[0].message.chat.id 확인.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── (선택) 폰에서 열 보드 주소 — 알림의 "보드 열기" 링크 ──
# 비워두면 start.ps1 -Tunnel 이 감지해 기록한 state/public_url.txt 를 사용한다.
# 고정 도메인이 있으면 여기에 직접 지정(예: https://cbr.example.com).
# CBR_PUBLIC_URL=

# ── (선택) 저장 위치 — 기본값 있음. 보통 비워둠 ──
# CBR_STATE_DIR=
# CBR_DB_PATH=

# ── (선택) 스캔 유니버스 크기 — D-1 거래대금 상위 N (KOSPI∪KOSDAQ). 기본 200 ──
# 확대 검증(백테스트) 후 상향 권장(예: 500~600). 라이브·백테스트가 같은 값을 사용한다.
# CBR_UNIVERSE_N=200
